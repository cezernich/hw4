<h1>Places</h1>

<ul class="list-group mb-3">
  <% for place in @places %>
    <li class="list-group-item">
      <a href="/places/<%= place["id"] %>"><%= place["name"] %></a>
    </li>
  <% end %>
</ul>

<% if @current_user != nil %>
  <p>
    <a class="btn btn-primary" href="/places/new">New place</a>
  </p>
<% end %>
