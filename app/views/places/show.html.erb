<h1><%= @place["name"] %></h1>

<h2 class="mb-3">My Entries</h2>

<div class="row">
  <% for entry in @entries %>
    <div class="col-12 col-md-4 mb-4">
      <div class="card h-100">
        <% if entry["image"] != nil && entry["image"] != "" %>
          <img src="<%= entry["image"] %>" class="card-img-top" alt="<%= entry["title"] %>">
        <% end %>
        <div class="card-body">
          <h5 class="card-title"><%= entry["title"] %></h5>
          <h6 class="card-subtitle mb-2 text-muted"><%= entry["occurred_on"] %></h6>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>

<p>
  <a class="btn btn-primary" href="/entries/new?place_id=<%= @place["id"] %>">New Entry</a>
  <a class="btn btn-secondary" href="/places">Back to All Places</a>
</p>
